# Handle your local home lab domain
home.woutvdb.be {
    file /etc/coredns/vdbhome.db
    log
    errors
    reload
}

home.vdbossche.info {
    file /etc/coredns/vdbossche.db
    log
    errors
    reload
}

# Handle all other internet traffic (Forwarding)
. {
    forward . 192.168.0.1 1.1.1.1
    cache 30
    log
    errors
}